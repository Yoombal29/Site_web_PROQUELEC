h3{color:#134a86}
.muted{color:#475569;font-size:0.95rem}
.section{margin-top:14px}
.toc{margin-top:12px}
.toc li{margin-bottom:6px}
.table{width:100%;border-collapse:collapse;margin-top:10px}
.table th,.table td{border:1px solid #e6eefc;padding:8px;text-align:left}
.checklist{background:#f1f5f9;padding:10px;border-radius:6px}
.footer{margin-top:28px;color:#64748b;font-size:0.92rem;border-top:1px solid #e6eefc;padding-top:10px}
