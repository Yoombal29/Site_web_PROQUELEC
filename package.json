  "type": "module",
  "scripts": {
    "dev": "npm run sync:docs && concurrently \"npm run migrate:auto && node server/index.js\" \"node server/dashboard-api.mjs\" \"vite --port 5175\"",
    "build": "npm run sync:docs && vite build",
    "build:dev": "npm run sync:docs && vite build --mode development",
    "sync:docs": "node scripts/sync-ia-docs.cjs",
    "lint": "eslint .",
    "preview": "vite preview",
    "start:clean": "./scripts/clean-and-start.sh",
    "prepare": "husky install",
    "db:start": "cd docker && docker-compose up -d",
    "db:stop": "cd docker && docker-compose down",
    "db:status": "docker ps --filter name=proquelec-",
    "db:reset": "powershell -Command \"docker exec -i proquelec-db psql -U postgres -d postgres -c 'DROP SCHEMA public CASCADE; CREATE SCHEMA public;' && npm run migrate:auto\"",
    "db:migrate": "npm run migrate:auto",
    "db:logs": "docker logs -f proquelec-db",
    "db:seed": "node scripts/seed-corpus.js",
    "migrate:auto": "node scripts/auto-migrate.js",
    "migrate:auto:win": "powershell -ExecutionPolicy Bypass -File scripts/auto-migrate.ps1",
    "dev:full": "npm run migrate:auto && npm run dev",
    "setup": "npm install && npm run migrate:auto",
    "deploy": "./scripts/deploy.sh",
    "deploy:win": "powershell -ExecutionPolicy Bypass -File scripts/deploy.ps1",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest run --run",
    "test:vitest": "vitest",
    "test:vitest:ui": "vitest --ui",
    "test:vitest:run": "vitest run",
    "test:vitest:coverage": "vitest --coverage",
    "server:collab": "node server/collaboration.js",
    "quick-start": "node quick-start.cjs start",
    "test-sync": "node test-sync-e2e.cjs",
    "test-latency": "node test-full-sync.cjs",
    "test-all": "node quick-start.cjs test-all"
  },
