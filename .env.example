# PROQUELEC Local API Configuration
VITE_API_URL=http://localhost:3000
VITE_JWT_SECRET=your_jwt_secret_here
JWT_SECRET=your_jwt_secret_here

# Database Configuration (PostgreSQL Local)
DATABASE_URL=postgresql://postgres:your_password@localhost:5434/postgres

# ============================================================
# REMOTE CLOUD AI CONFIGURATION (Recommended)
# ============================================================

# Master Switch: Enable remote IA (1/true to enable)
PROQUELEC_REMOTE_AI=1

# AI Provider Selection (openai | anthropic | custom)
PROQUELEC_AI_PROVIDER=openai

# API Key for selected provider
# - OpenAI: https://platform.openai.com/account/api-keys
# - Anthropic: https://console.anthropic.com/
PROQUELEC_API_KEY=sk-proj-xxxxxxxxxxxxx

# AI Model to use (optional, defaults based on provider)
# - OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# - Anthropic: claude-3.5, claude-3, claude-2
PROQUELEC_AI_MODEL=gpt-4o

# Custom API Endpoint (only if PROQUELEC_AI_PROVIDER=custom)
PROQUELEC_AI_API_URL=https://your-api.com/v1/chat/completions

# Remote Image Generation Service
# - For OpenAI: https://api.openai.com/v1/images/generations
# - For custom: your image generation endpoint
PROQUELEC_REMOTE_IMAGE_API=https://api.openai.com/v1/images/generations
PROQUELEC_IMAGE_API_KEY=sk-proj-xxxxxxxxxxxxx

# Remote Vision/Image Analysis Service (optional)
# If not set, defaults to PROQUELEC_REMOTE_IMAGE_API
PROQUELEC_REMOTE_VISION_API=https://your-vision-api.com/v1/analyze

# ============================================================
# LOCAL AI SERVICES (Legacy, used if PROQUELEC_REMOTE_AI=0)
# ============================================================

# AI Microservices URLs
AI_BRAIN_URL=http://localhost:8002
AI_VISION_URL=http://localhost:8003
AI_IMAGE_URL=http://localhost:8004

# Frontend API Keys (for direct frontend calls if needed)
VITE_GEMINI_API_KEY=your_gemini_api_key_here
VITE_OPENAI_API_KEY=your_openai_api_key_here

# ============================================================
# EMAIL CONFIGURATION
# ============================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
